rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper functions ----------
    function isAuthenticated() { return request.auth != null; }
    function getRole()          { return request.auth.token.role; }
    function getVillageId()     { return request.auth.token.villageId; }
    function isAdmin()          { return isAuthenticated() && getRole() == 'admin'; }
    function isSuperAdmin()     { return isAuthenticated() && getRole() == 'super_admin'; }
    function isDistrictOfficer(){ return isAuthenticated() && getRole() == 'district_officer'; }
    function isVillager()       { return isAuthenticated() && getRole() == 'villager'; }
    function sameVillage(v)     { return isAuthenticated() && getVillageId() == v; }
    function isVillageAdmin(v)  { return isAdmin() && sameVillage(v); }

    function unchanged(field) {
      return !(field in request.resource.data.diff(resource.data).affectedKeys());
    }

    // Base64-in-Firestore file limit. Firestore's hard document cap is 1 MiB
    // (1,048,576 bytes). We cap the base64 payload itself well under that to
    // leave room for metadata fields and Firestore's internal overhead.
    function withinFileLimit(field) {
      return field.size() < 900000; // ~900 KB of base64 text per document
    }

    function isAllowedMimeType(mime) {
      return mime in ['image/jpeg', 'image/png', 'application/pdf'];
    }

    // ---------- villages ----------
    match /villages/{villageId} {
      allow read: if isAuthenticated() &&
        (sameVillage(villageId) || isDistrictOfficer() || isSuperAdmin());
      allow write: if isSuperAdmin();
    }

    // ---------- users ----------
    // Phone OTP users: created by onUserCreate Cloud Function (Admin SDK).
    // Email/password users: may create their own users/{uid} doc once at signup.
    match /users/{userId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId ||
         (isAdmin() && sameVillage(resource.data.villageId)) ||
         isSuperAdmin());
      allow update: if isAuthenticated() && request.auth.uid == userId &&
        unchanged('role') && unchanged('villageId') && unchanged('memberId');
      allow create: if isSuperAdmin() ||
        (isAuthenticated() && request.auth.uid == userId &&
         request.resource.data.email is string &&
         request.resource.data.name is string &&
         request.resource.data.role in ['villager', 'admin'] &&
         request.resource.data.villageId is string);
      allow delete: if isSuperAdmin();

      // Face embedding stored as a private subdocument, never on the parent
      // users/{uid} doc itself, so it can never leak via a broader users read.
      match /private/faceEmbedding {
        allow read, write: if isAuthenticated() &&
          (request.auth.uid == userId || isSuperAdmin());
        allow create, update: if isAuthenticated() &&
          (request.auth.uid == userId || isSuperAdmin()) &&
          withinFileLimit(request.resource.data.base64Data);
      }
    }

    // ---------- village_members ----------
    match /village_members/{memberId} {
      allow read: if isAuthenticated() && sameVillage(resource.data.villageId);
      allow create: if isVillageAdmin(request.resource.data.villageId);
      allow update: if isVillageAdmin(resource.data.villageId) &&
        request.resource.data.villageId == resource.data.villageId;
      allow delete: if isSuperAdmin();

      match /attendance_summary/{summaryId} {
        allow read: if isAuthenticated() &&
          sameVillage(get(/databases/$(database)/documents/village_members/$(memberId)).data.villageId);
        allow write: if false; // system/Cloud-Function maintained only
      }
    }

    // ---------- claims ----------
    match /claims/{claimId} {
      allow read: if isAuthenticated() && (
        (isVillager() && resource.data.claimantUserId == request.auth.uid) ||
        (isAdmin() && sameVillage(resource.data.villageId)) ||
        isDistrictOfficer() || isSuperAdmin()
      );
      allow create: if isAuthenticated() &&
        request.resource.data.claimantUserId == request.auth.uid &&
        sameVillage(request.resource.data.villageId) &&
        request.resource.data.status == 'draft';
      allow update: if isAuthenticated() && (
        (isVillager() &&
         resource.data.claimantUserId == request.auth.uid &&
         resource.data.status == 'draft' &&
         unchanged('claimantUserId') && unchanged('villageId')) ||
        (isVillageAdmin(resource.data.villageId) &&
         unchanged('claimantUserId') && unchanged('villageId'))
      );
      allow delete: if isSuperAdmin();

      match /status_history/{historyId} {
        allow read: if isAuthenticated() &&
          (get(/databases/$(database)/documents/claims/$(claimId)).data.claimantUserId == request.auth.uid ||
           isAdmin() || isDistrictOfficer() || isSuperAdmin());
        allow create: if isAuthenticated();
        allow update, delete: if false; // IMMUTABLE
      }

      // Replaces Firebase Storage: each uploaded photo/scan becomes ONE document
      // here, holding the file as a base64 string. Denormalize claimantUserId +
      // villageId onto every doc so reads/writes don't need an extra get().
      match /documents/{docId} {
        allow read: if isAuthenticated() && (
          resource.data.claimantUserId == request.auth.uid ||
          (isAdmin() && sameVillage(resource.data.villageId)) ||
          isDistrictOfficer() || isSuperAdmin()
        );
        allow create: if isAuthenticated() &&
          request.resource.data.claimantUserId == request.auth.uid &&
          sameVillage(request.resource.data.villageId) &&
          isAllowedMimeType(request.resource.data.mimeType) &&
          withinFileLimit(request.resource.data.base64Data);
        allow update: if false; // re-upload as a new doc instead of editing in place
        allow delete: if isVillageAdmin(resource.data.villageId) || isSuperAdmin();
      }
    }

    // ---------- gram_sabha_meetings ----------
    match /gram_sabha_meetings/{meetingId} {
      allow read: if isAuthenticated() && sameVillage(resource.data.villageId);
      allow create: if isVillageAdmin(request.resource.data.villageId);
      allow update: if isVillageAdmin(resource.data.villageId) &&
        request.resource.data.villageId == resource.data.villageId;
      allow delete: if isSuperAdmin();

      // Meeting minutes PDFs are usually bigger than one document can hold, so
      // they're split client-side into ordered chunks. See integration plan
      // "Chunked Base64 Storage" section for the encode/decode helper.
      match /minutes_chunks/{chunkId} {
        allow read: if isAuthenticated() &&
          sameVillage(get(/databases/$(database)/documents/gram_sabha_meetings/$(meetingId)).data.villageId);
        allow create: if isVillageAdmin(get(/databases/$(database)/documents/gram_sabha_meetings/$(meetingId)).data.villageId) &&
          withinFileLimit(request.resource.data.base64Chunk);
        allow update, delete: if false; // write once; re-generate minutes as a new set of chunks + bump version
      }
    }

    // ---------- attendance_records ----------
    match /attendance_records/{attendanceId} {
      allow read: if isAuthenticated() && sameVillage(resource.data.villageId);
      allow create: if isAuthenticated() &&
        sameVillage(request.resource.data.villageId) &&
        get(/databases/$(database)/documents/gram_sabha_meetings/$(request.resource.data.meetingId)).data.villageId == request.resource.data.villageId;
      allow update: if isVillageAdmin(resource.data.villageId);
      allow delete: if false; // NEVER delete attendance
    }

    // ---------- resolutions (hash-chain ledger) ----------
    match /resolutions/{resolutionId} {
      allow read: if isAuthenticated() && (
        sameVillage(resource.data.villageId) ||
        isDistrictOfficer() || isSuperAdmin()
      );
      allow create: if isVillageAdmin(request.resource.data.villageId);
      allow update, delete: if false; // IMMUTABLE — preserves hash chain
    }

    // ---------- notices ----------
    match /notices/{noticeId} {
      allow read: if isAuthenticated() && (
        resource.data.villageId == null ||
        sameVillage(resource.data.villageId) ||
        isSuperAdmin()
      );
      allow create, update: if isSuperAdmin() ||
        (isAdmin() && request.resource.data.villageId != null &&
         sameVillage(request.resource.data.villageId));
      allow delete: if isSuperAdmin();
    }

    // ---------- boundary_alerts ----------
    match /boundary_alerts/{alertId} {
      allow read: if isAuthenticated() && (
        sameVillage(resource.data.villageId) ||
        isDistrictOfficer() || isSuperAdmin()
      );
      allow create: if isVillageAdmin(request.resource.data.villageId) || isSuperAdmin();
      allow update: if isVillageAdmin(resource.data.villageId) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      // Before/after satellite images as base64 documents (replaces Storage paths)
      match /images/{imageId} {
        allow read: if isAuthenticated() && (
          sameVillage(get(/databases/$(database)/documents/boundary_alerts/$(alertId)).data.villageId) ||
          isDistrictOfficer() || isSuperAdmin()
        );
        allow create: if (isVillageAdmin(get(/databases/$(database)/documents/boundary_alerts/$(alertId)).data.villageId) || isSuperAdmin()) &&
          isAllowedMimeType(request.resource.data.mimeType) &&
          withinFileLimit(request.resource.data.base64Data);
        allow update, delete: if isSuperAdmin();
      }
    }

    // ---------- sync_audit_log ----------
    match /sync_audit_log/{logId} {
      allow read: if isAdmin() || isSuperAdmin();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        sameVillage(request.resource.data.villageId);
      allow update, delete: if false; // append-only
    }
  }
}
